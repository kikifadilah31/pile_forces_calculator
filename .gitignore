# Virtual environment
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Temp files
*.tmp
*.bak

# CLI run outputs (timestamped, never committed)
output/

# uv lockfile is intentionally NOT committed: its presence makes Streamlit
# Community Cloud use `uv sync` (editable install + drops [web] extras),
# which breaks the hosted app. Cloud uses requirements.txt instead.
uv.lock
